  \"column\": \"plasma_CA19_9\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 2.2811527341299884,\n        \"min\": 0.0,\n        \"max\": 10.34177474101152,\n        \"num_unique_values\": 266,\n        \"samples\": [\n          5.765191102784844,\n          4.762173934797756,\n          5.545177444479562\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"creatinine\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.3095513199971318,\n        \"min\": 0.05500888303079915,\n        \"max\": 1.6325370610128085,\n        \"num_unique_values\": 198,\n        \"samples\": [\n          0.7242290941229739,\n          0.21310129623613958,\n          0.3495788259419604\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"LYVE1\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.8433094669024315,\n        \"min\": 0.00012942162466022237,\n        \"max\": 3.2144790933945355,\n        \"num_unique_values\": 535,\n        \"samples\": [\n          0.7323621244658153,\n          0.10963436971873153,\n          0.5289814841207736\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"REG1B\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 1.5743521615316258,\n        \"min\": 0.001103812574690165,\n        \"max\": 7.247719696549505,\n        \"num_unique_values\": 580,\n        \"samples\": [\n          5.057779660238347,\n          3.8989102680343564,\n          2.9869942076107057\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"TFF1\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 2.226807626614792,\n        \"min\": 0.005279120888187838,\n        \"max\": 9.4