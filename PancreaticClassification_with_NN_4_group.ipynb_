сем наблюдениям. Таким образом мы пользуемся свойством распределений, при добавлении константы ко всем наблюдениям форма распределения никак не меняется."],"metadata":{"id":"tjvVuqbl5hPG"},"id":"tjvVuqbl5hPG"},{"cell_type":"code","source":["for column in numerical_cols[1:]:\n","    copy_data[column] = np.log1p(copy_data[column])"],"metadata":{"id":"D5ZppeLY5gxm","executionInfo":{"status":"ok","timestamp":1773606320725,"user_tz":-180,"elapsed":49,"user":{"displayName":"Daria Lukyanenko","userId":"17896998785669715202"}}},"id":"D5ZppeLY5gxm","execution_count":16,"outputs":[]},{"cell_type":"markdown","id":"ec1201b2-b860-40f8-8744-b46adae85328","metadata":{"id":"ec1201b2-b860-40f8-8744-b46adae85328"},"source":["Проверяем результаты предобработки"]},{"cell_type":"code","source":["copy_data = copy_data.set_index('sample_id')"],"metadata":{"id":"LILuft5M6qN7","executionInfo":{"status":"ok","timestamp":1773606320734,"user_tz":-180,"elapsed":5,"user":{"displayName":"Daria Lukyanenko","userId":"17896998785669715202"}}},"id":"LILuft5M6qN7","execution_count":17,"outputs":[]},{"cell_type":"code","execution_count":18,"id":"acc419bc-358e-4233-84c5-39b8066f4534","metadata":{"id":"acc419bc-358e-4233-84c5-39b8066f4534","outputId":"69f8b098-5761-4dfe-f9b1-f244ad6f86e1","colab":{"base_uri":"https://localhost:8080/","height":175},"executionInfo":{"status":"ok","timestamp":1773606320782,"user_tz":-180,"elapsed":50,"user":{"displayName":"Daria Lukyanenko","userId":"17896998785669715202"}}},"outputs":[{"output_type":"execute_result","data":{"text/plain":["       patient_cohort sample_origin stage benign_sample_diagnosis\n","count             590           590   199                     208\n","unique              2             4     8                      52\n","top           Cohort1          BPTB   III            Pancreatitis\n","freq              332           409    76                      41"],"text/html":["\n","  <div id=\"df-9cde5f75-fde7-4cb9-b837-6bf40d290788\" class=\"colab-df-cont